generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  OFFICER
  USER
}

model BantaiUser {
  id           String    @id @default(uuid())
  username     String    @unique
  email        String?   @unique
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  passwordHash String    @map("password")
  role         UserRole
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@map("bantai_users")
}

enum JeepneyStatus {
  ACTIVE
  INACTIVE
}

model MPUJMetadata {
  id               String         @id @default(uuid())
  vehicleId        String         @unique @map("vehicle_id")
  driverName       String         @map("driver_name")
  plateNumber      String         @map("plate_number")
  vehicleType      String         @map("vehicle_type")
  vehicleModel     String         @map("vehicle_model")
  operator         String
  routeName        String         @map("route_name")
  routeCode        String?        @map("route_code")
  description      String?        @map("description")
  sittingCapacity  Int            @map("sitting_capacity")
  standingCapacity Int            @map("standing_capacity")
  speedLimit       Int            @map("speed_limit")
  status           JeepneyStatus  @default(ACTIVE)
  registrationDate DateTime       @default(now()) @map("registration_date")
  violationCount   Int            @default(0) @map("violation_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  @@map("mpuj_metadata")
}
