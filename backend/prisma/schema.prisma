generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      String   @default("USER")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  violations Violation[] @relation("IssuedBy")

  @@map("users")
}

model Jeepney {
  id            String    @id @default(uuid())
  plateNumber   String    @unique
  ownerName     String
  ownerContact  String?
  ownerAddress  String?
  route         String
  bodyNumber    String?
  engineNumber  String?
  chassisNumber String?
  color         String?
  yearModel     Int?
  status        String    @default("PENDING")
  registeredAt  DateTime  @default(now())
  expiresAt     DateTime?
  updatedAt     DateTime  @updatedAt

  violations    Violation[]
  registrations Registration[]

  @@map("jeepneys")
}

model Violation {
  id          String    @id @default(uuid())
  jeepneyId   String
  jeepney     Jeepney   @relation(fields: [jeepneyId], references: [id], onDelete: Cascade)
  issuedById  String
  issuedBy    User      @relation("IssuedBy", fields: [issuedById], references: [id])
  type        String    @default("OTHER")
  description String
  location    String?
  fineAmount  Float?
  status      String    @default("PENDING")
  issuedAt    DateTime  @default(now())
  resolvedAt  DateTime?
  updatedAt   DateTime  @updatedAt
  notes       String?

  @@map("violations")
}

model Registration {
  id            String   @id @default(uuid())
  jeepneyId     String
  jeepney       Jeepney  @relation(fields: [jeepneyId], references: [id], onDelete: Cascade)
  registeredAt  DateTime @default(now())
  expiresAt     DateTime
  receiptNumber String?  @unique
  amountPaid    Float?
  remarks       String?
  updatedAt     DateTime @updatedAt

  @@map("registrations")
}