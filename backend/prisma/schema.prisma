datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum TripStatus {
  ON_TRIP
  COMPLETED
}

enum DispatchStatus {
  ON_TRIP
  AT_TERMINAL
}

enum VehicleState {
  FULL
  AVAILABLE
}

enum IncidentType {
  OVERCAPACITY
  OVERSPEEDING
}

enum IncidentStatus {
  PENDING
  APPROVED
  DISMISSED
}

enum IncidentTripStatus {
  ACTIVE
  INACTIVE
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

//////////////////////////////////////////////////////
// MODELS
//////////////////////////////////////////////////////

model Operator {
  operator_id    String @id @default(uuid())
  operator_name  String
  email          String @unique
  contact_number String

  drivers  Driver[]
  vehicles Vehicle[]
  users    Operator_User[]

  @@map("operator")
}

model Driver {
  driver_id   String @id @default(uuid())
  driver_name String
  operator_id String

  operator Operator  @relation(fields: [operator_id], references: [operator_id])
  vehicles Vehicle[]

  @@map("driver")
}

model Operator_User {
  user_id        String @id @default(uuid())
  operator_id    String
  username       String @unique
  password_hash  String
  employee_name  String
  email          String @unique
  contact_number String
  role           String

  operator Operator @relation(fields: [operator_id], references: [operator_id])

  @@map("operator_user")
}

model Route {
  route_id           String @id @default(uuid())
  route_name         String
  terminal_latitude  Float
  terminal_longitude Float

  vehicles Vehicle[]

  @@map("route")
}

model Vehicle {
  vehicle_id        String        @id @default(uuid())
  operator_id       String
  driver_id         String
  route_id          String
  vehicle_code      String
  plate_number      String
  sitting_capacity  Int
  standing_capacity Int
  speed_limit       Int
  status            VehicleStatus @default(ACTIVE)

  operator Operator @relation(fields: [operator_id], references: [operator_id])
  driver   Driver   @relation(fields: [driver_id], references: [driver_id])
  route    Route    @relation(fields: [route_id], references: [route_id])

  trips          Trip[]
  dispatchQueues Dispatch_Queue[]
  statuses       Vehicle_Status[]
  etaRequests    ETA_Request[]

  @@map("vehicle")
}

model Trip {
  trip_id              String     @id @default(uuid())
  vehicle_id           String
  start_trip_timestamp DateTime
  end_trip_timestamp   DateTime?
  trip_status          TripStatus
  dispatch_type        String

  vehicle Vehicle @relation(fields: [vehicle_id], references: [vehicle_id])

  incidents   Incident[]
  etaRequests ETA_Request[]

  @@map("trip")
}

model Dispatch_Queue {
  queue_id        String         @id @default(uuid())
  vehicle_id      String
  position        Int
  status          DispatchStatus
  entry_timestamp DateTime

  vehicle Vehicle @relation(fields: [vehicle_id], references: [vehicle_id])

  @@map("dispatch_queue")
}

model Vehicle_Status {
  status_id                String       @id @default(uuid())
  vehicle_id               String
  standing_passenger_count Int
  sitting_passenger_count  Int
  vehicle_latitude         Float
  vehicle_longitude        Float
  vehicle_state            VehicleState
  timestamp                DateTime

  vehicle Vehicle @relation(fields: [vehicle_id], references: [vehicle_id])

  @@map("vehicle_status")
}

//////////////////////////////////////////////////////
// INCIDENT SYSTEM (NORMALIZED)
//////////////////////////////////////////////////////

model Incident {
  incident_id          String             @id @default(uuid())
  trip_id              String
  incident_type        IncidentType
  incident_status      IncidentStatus     @default(PENDING)
  incident_trip_status IncidentTripStatus @default(ACTIVE)
  timestamp            DateTime           @default(now())

  trip Trip @relation(fields: [trip_id], references: [trip_id])

  overcapacityDetails Overcapacity_Violations?
  overspeedingDetails Overspeeding_Violations?

  @@map("incident")
}

model Overcapacity_Violations {
  id                 String @id @default(uuid())
  incident_id        String @unique
  threshold_sitting  Int
  threshold_standing Int
  measured_sitting   Int
  measured_standing  Int
  incident_snapshot  Json?

  incident Incident @relation(fields: [incident_id], references: [incident_id])

  @@map("overcapacity_violations")
}

model Overspeeding_Violations {
  id           String @id @default(uuid())
  incident_id  String @unique
  speed        Float
  speed_limit  Float
  speed_excess Float

  incident Incident @relation(fields: [incident_id], references: [incident_id])

  @@map("overspeeding_violations")
}

//////////////////////////////////////////////////////
// ETA SYSTEM
//////////////////////////////////////////////////////

model ETA_Request {
  request_id                 String   @id @default(uuid())
  commuter_id                String
  vehicle_id                 String
  trip_id                    String
  request_location_latitude  Float
  request_location_longitude Float
  ETA                        Float
  distance_value             Float
  timestamp                  DateTime

  vehicle  Vehicle  @relation(fields: [vehicle_id], references: [vehicle_id])
  trip     Trip     @relation(fields: [trip_id], references: [trip_id])
  commuter Commuter @relation(fields: [commuter_id], references: [commuter_id])

  @@map("eta_request")
}

model Commuter {
  commuter_id String @id @default(uuid())

  etaRequests ETA_Request[]

  @@map("commuter")
}